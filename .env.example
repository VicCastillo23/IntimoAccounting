# --- Vista previa / staging (como en local; aún no “productivo”) ---
# Deja NODE_ENV=development (o sin definir). Así: cookie sin Secure (vale HTTP),
# primer arranque puede usar admin / admin si no pones ACCOUNTING_ADMIN_*.
NODE_ENV=development
PORT=3010
# Detrás de Nginx u otro proxy: IP real del cliente (rate limit en login, etc.)
TRUST_PROXY=1
# Opcional: URL pública para enlaces / futuras integraciones
# PUBLIC_BASE_URL=https://contabilidad.cafeintimo.mx

# --- Cuando pases a productivo ---
# NODE_ENV=production
# (quita TRUST_PROXY si no hay proxy; con Nginx suele seguir haciendo falta el proxy, déjalo en 1)
# Cookie Secure y obligatorio definir ACCOUNTING_ADMIN_* en el primer arranque (sin users.enc).

# Obligatorio: 64 caracteres hex = 32 bytes (npm run gen:data-key)
# Cifra users.enc y polizas.enc en disco.
DATA_ENCRYPTION_KEY=

# Obligatorio: al menos 32 caracteres (npm run gen:session-secret)
# Firma la cookie de sesión httpOnly.
SESSION_SECRET=

# Solo la primera vez que no exista data/users.enc:
# En producción son obligatorios. En desarrollo, si faltan, se usa admin / admin (ver consola).
ACCOUNTING_ADMIN_USER=
ACCOUNTING_ADMIN_PASSWORD=

# Opcional: misma instancia RDS que Loyalty (esquema accounting.*)
# postgresql://USER:PASSWORD@HOST:5432/intimo_loyalty
# DATABASE_URL=
# PG_POOL_MAX=8

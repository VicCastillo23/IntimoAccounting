{
  "name": "intimo-accounting",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "Contabilidad Íntimo — pólizas y reportes (misma familia visual que IntimoInvoicing)",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate-catalog": "node scripts/run-sql-files.mjs",
    "db:migrate-all": "node scripts/run-sql-files.mjs --all",
    "db:seed-reporting": "node scripts/seed-reporting-demo.mjs",
    "db:migrate-intimo-codes": "node scripts/migrate-intimo-account-codes.mjs",
    "setup:local": "bash scripts/setup-local-native.sh",
    "pg:stop": "bash scripts/stop-local-pg.sh",
    "gen:data-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "gen:session-secret": "node -e \"console.log(require('crypto').randomBytes(48).toString('base64'))\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "pg": "^8.13.1",
    "xlsx": "^0.18.5"
  }
}
